<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MonitoringApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryContainer">@color/surface_variant</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorError">@color/status_error</item>
        <item name="colorOnError">@color/text_on_accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="materialCardViewStyle">@style/Widget.Monitoring.Card</item>
        <item name="materialButtonStyle">@style/Widget.Monitoring.Button.Primary</item>
        <item name="monitoringButtonStyle">@style/Widget.Monitoring.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.Monitoring.TextInput</item>
    </style>

    <!-- Карточки -->
    <style name="Widget.Monitoring.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeWidth">@dimen/card_stroke_default</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <!-- Нижняя навигация -->
    <style name="Widget.Monitoring.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:minHeight">@dimen/bottom_nav_min_height</item>
        <item name="itemIconSize">22dp</item>
        <item name="itemPaddingTop">@dimen/bottom_nav_item_padding_top</item>
        <item name="itemPaddingBottom">@dimen/bottom_nav_item_padding_bottom</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.Monitoring.BottomNav</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.Monitoring.BottomNav</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="TextAppearance.Monitoring.BottomNav" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Вкладки -->
    <style name="Widget.Monitoring.Tab" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/text_on_primary</item>
        <item name="tabSelectedTextColor">@color/text_on_primary</item>
        <item name="tabTextColor">@color/text_on_primary_muted</item>
        <item name="tabMode">scrollable</item>
    </style>

    <!-- Поля ввода -->
    <style name="Widget.Monitoring.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/search_background</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Monitoring.Search" parent="Widget.Monitoring.TextInput">
        <item name="boxStrokeColor">@color/divider</item>
    </style>

    <!-- Чип -->
    <style name="Widget.Monitoring.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_variant</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <!-- Типографика -->
    <style name="TextAppearance.Monitoring.Headline.OnPrimary" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Monitoring.Headline" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Monitoring.Subtitle.OnPrimary" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:textColor">@color/text_on_primary_muted</item>
    </style>

    <style name="TextAppearance.Monitoring.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Monitoring.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Monitoring.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Monitoring.Body.Secondary" parent="TextAppearance.Monitoring.Body">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Monitoring.Label" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">@dimen/text_size_label</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Monitoring.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Monitoring.StatLarge" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">@dimen/text_size_stat_large</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Monitoring.Stat" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_stat</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Кнопки -->
    <style name="Widget.Monitoring.Button" parent="Widget.Material3.Button">
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/card_corner_radius</item>
    </style>

    <style name="Widget.Monitoring.Button.Primary" parent="Widget.Monitoring.Button">
        <item name="backgroundTint">@color/button_primary_bg</item>
        <item name="android:textColor">@color/button_primary_text</item>
    </style>

    <style name="Widget.Monitoring.Button.Accent" parent="Widget.Monitoring.Button">
        <item name="backgroundTint">@color/button_accent_bg</item>
        <item name="android:textColor">@color/button_accent_text</item>
    </style>

    <style name="Widget.Monitoring.Button.Secondary" parent="Widget.Monitoring.Button">
        <item name="backgroundTint">@color/primary_light</item>
        <item name="android:textColor">@color/button_primary_text</item>
    </style>

    <style name="Widget.Monitoring.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/button_outlined_stroke</item>
        <item name="android:textColor">@color/button_outlined_text</item>
        <item name="cornerRadius">@dimen/card_corner_radius</item>
    </style>

    <style name="Widget.Monitoring.Button.Outlined.Destructive" parent="Widget.Monitoring.Button.Outlined">
        <item name="strokeColor">@color/button_destructive_stroke</item>
        <item name="android:textColor">@color/button_destructive_text</item>
    </style>

    <style name="Widget.Monitoring.Button.Compact" parent="Widget.Monitoring.Button.Outlined">
        <item name="android:minHeight">@dimen/button_height_compact</item>
        <item name="android:textSize">@dimen/text_size_label</item>
    </style>

    <style name="Widget.Monitoring.Button.Compact.Destructive" parent="Widget.Monitoring.Button.Outlined.Destructive">
        <item name="android:minHeight">@dimen/button_height_compact</item>
        <item name="android:textSize">@dimen/text_size_label</item>
    </style>

    <!-- Баннер офлайн -->
    <style name="Widget.Monitoring.Banner.Warning" parent="Widget.Monitoring.Card">
        <item name="cardBackgroundColor">@color/severity_warning_bg</item>
    </style>
</resources>
